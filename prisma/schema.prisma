generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  company   String?
  service   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  tag         String
  description String
  details     String
  techStack   String
  features    String
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  initials  String
  role      String
  bio       String
  tagline   String   @default("")
  skills    String   @default("") // comma-separated
  linkedin  String   @default("")
  twitter   String   @default("")
  photo     String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  logo        String   @default("") // path in /public/partners/
  website     String   @default("")
  category    String   @default("") // ex: Institutionnel, Technologie, Académique
  description String   @default("")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Stat {
  id    String @id @default(cuid())
  value String
  label String
  order Int    @default(0)
}
